# ---------------------------------------------------------------------------
# Client-safe variables (VITE_-prefixed → shipped to the browser bundle).
# These are validated on startup by src/config/env.ts.
# The anon key is public by design; access is gated by Row Level Security.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Server-side ONLY — never prefix with VITE_, never expose to the client.
# Used exclusively by Supabase Edge Functions / trusted backend code.
# ---------------------------------------------------------------------------
# Supabase service role key (bypasses RLS — keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# AI provider key (server-side edge functions only)
ANTHROPIC_API_KEY=
